#!/usr/bin/env bash

set -euo pipefail

if ! git rev-parse --is-inside-work-tree >/dev/null 2>&1; then
	>&2 echo "ERROR: Not in a Git repository"
	exit 1
fi

currentBranch=$(git branch --show-current 2>/dev/null)

target='master'
interactive=0
while [ $# -gt 0 ]; do
	case "$1" in
		-t|--target)
			if [ $# -lt 2 ]; then
				>&2 echo "ERROR: $1 requires an argument"
				exit 1
			fi
			target=$2
			shift 2
			;;
		-i|--interactive) interactive=1; shift ;;
		--) shift; break ;;
		*) break ;;
	esac
done

git for-each-ref --format='%(refname:short)' "--merged=${target}" refs/heads/ |
grep -Fvx "$target" |
while read branch; do
	if [[ "$branch" == "$currentBranch" ]]; then
		echo "Not deleting '$branch' because it is the current branch"
		continue
	fi

	if [[ "$branch" == rc/* || "$branch" == rel/* ]]; then
		echo "Not deleting '$branch' because it is a release branch"
		continue
	fi

	if [[ "$interactive" -eq 1 ]]; then
		read -r -p "Delete '$branch'? [y/N] " reply </dev/tty
		if [[ ! "$reply" =~ ^[Yy]$ ]]; then
			echo "Skipping '$branch'"
			continue
		fi
	fi

	git branch -d "$branch"
done
